# PlasterPro Ghana - Environment Variables

# Formspree Form IDs (Get these from https://formspree.io after creating forms)
# 1. Create a Formspree account at https://formspree.io
# 2. Create two forms: "Contact Form" and "Meeting Request Form"
# 3. Copy the form IDs and paste them below
VITE_FORMSPREE_CONTACT_FORM_ID=your_contact_form_id_here
VITE_FORMSPREE_MEETING_FORM_ID=your_meeting_form_id_here

# Google Analytics (Optional)
# Get your Measurement ID from Google Analytics (GA4)
# Format: G-XXXXXXXXXX
VITE_GA_MEASUREMENT_ID=

# Sanity CMS (Get these from https://sanity.io/manage after creating a project)
# 1. Run: npm create sanity@latest  → name it "plasterpro-gh", dataset "production"
# 2. Your project ID appears in the Sanity dashboard URL: manage.sanity.io/projects/<ID>
# 3. Add your Netlify site URL + http://localhost:5173 to CORS origins in the Sanity dashboard
VITE_SANITY_PROJECT_ID=your_sanity_project_id_here
VITE_SANITY_DATASET=production

# Application Info
VITE_APP_NAME=PlasterPro Ghana
VITE_APP_URL=https://plasterpro-ghana.com

# Contact Information
VITE_PHONE_PRIMARY=+233249718356
VITE_PHONE_SECONDARY=+2332444936551
VITE_EMAIL=plasterproent@gmail.com
VITE_ADDRESS=East Legon Hills, Accra, Ghana
VITE_WHATSAPP_NUMBER=233249718356
